{
  "manifest_version": 3,
  "name": "ReelCheck",
  "version": "0.1.0",
  "description": "Real-time health & fitness claim fact-checking for Instagram Reels",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["https://www.instagram.com/*", "http://localhost:3001/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["reel-extractor-main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "ReelCheck"
  }
}
